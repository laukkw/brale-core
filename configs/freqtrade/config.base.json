{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "api_server": {
    "CORS_origins": [],
    "enable_openapi": false,
    "enabled": true,
    "jwt_secret_key": "REPLACE_ME",
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8080,
    "password": "REPLACE_ME",
    "username": "REPLACE_ME",
    "verbosity": "info",
    "ws_token": "REPLACE_ME"
  },
  "bot_name": "freqtrade",
  "cancel_open_orders_on_exit": false,
  "dry_run": true,
  "dry_run_wallet": 1000,
  "entry_pricing": {
    "check_depth_of_market": {
      "bids_to_ask_delta": 1,
      "enabled": false
    },
    "order_book_top": 1,
    "price_last_balance": 0,
    "price_side": "same",
    "use_order_book": true
  },
  "exchange": {
    "key": "",
    "name": "binance",
    "pair_blacklist": [
      "BNB/.*"
    ],
    "pair_whitelist": [
      "BTC/USDT:USDT",
      "ETH/USDT:USDT",
      "SOL/USDT:USDT"
    ],
    "secret": ""
  },
  "exit_pricing": {
    "order_book_top": 1,
    "price_side": "same",
    "use_order_book": true
  },
  "fiat_display_currency": "USD",
  "force_entry_enable": true,
  "initial_state": "running",
  "internals": {
    "process_throttle_secs": 5
  },
  "margin_mode": "isolated",
  "max_open_trades": 10,
  "pairlists": [
    {
      "method": "VolumePairList",
      "min_value": 0,
      "number_assets": 5,
      "refresh_period": 1800,
      "sort_key": "quoteVolume"
    },
    {
      "method": "StaticPairList"
    }
  ],
  "stake_amount": 1000,
  "stake_currency": "USDT",
  "strategy": "BraleSharedStrategy",
  "telegram": {
    "chat_id": "REPLACE_ME",
    "enabled": false,
    "token": "REPLACE_ME"
  },
  "timeframe": "5m",
  "tradable_balance_ratio": 0.99,
  "trading_mode": "futures",
  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "webhook": {
    "enabled": true,
    "entry": {
      "direction": "{direction}",
      "leverage": "{leverage}",
      "open_date": "{open_date}",
      "open_rate": "{open_rate}",
      "order_rate": "{limit}",
      "pair": "{pair}",
      "stake_amount": "{stake_amount}",
      "trade_id": "{trade_id}",
      "type": "entry"
    },
    "entry_fill": {
      "amount": "{amount}",
      "direction": "{direction}",
      "open_date": "{open_date}",
      "open_rate": "{open_rate}",
      "order_rate": "{limit}",
      "pair": "{pair}",
      "stake_amount": "{stake_amount}",
      "trade_id": "{trade_id}",
      "type": "entry_fill"
    },
    "exit": {
      "amount": "{amount}",
      "close_date": "{close_date}",
      "close_rate": "{close_rate}",
      "direction": "{direction}",
      "exit_reason": "{exit_reason}",
      "pair": "{pair}",
      "trade_id": "{trade_id}",
      "type": "exit"
    },
    "exit_fill": {
      "amount": "{amount}",
      "close_date": "{close_date}",
      "close_rate": "{close_rate}",
      "direction": "{direction}",
      "exit_reason": "{exit_reason}",
      "pair": "{pair}",
      "trade_id": "{trade_id}",
      "type": "exit_fill"
    },
    "format": "json",
    "url": "http://brale:9991/api/live/freqtrade/webhook",
    "webhookentry": {
      "direction": "{direction}",
      "leverage": "{leverage}",
      "open_date": "{open_date}",
      "open_rate": "{open_rate}",
      "order_rate": "{limit}",
      "pair": "{pair}",
      "stake_amount": "{stake_amount}",
      "trade_id": "{trade_id}",
      "type": "entry"
    },
    "webhookentryfill": {
      "amount": "{amount}",
      "direction": "{direction}",
      "open_date": "{open_date}",
      "open_rate": "{open_rate}",
      "order_rate": "{limit}",
      "pair": "{pair}",
      "stake_amount": "{stake_amount}",
      "trade_id": "{trade_id}",
      "type": "entry_fill"
    },
    "webhookexit": {
      "amount": "{amount}",
      "close_date": "{close_date}",
      "close_rate": "{close_rate}",
      "direction": "{direction}",
      "exit_reason": "{exit_reason}",
      "pair": "{pair}",
      "trade_id": "{trade_id}",
      "type": "exit"
    },
    "webhookexitfill": {
      "amount": "{amount}",
      "close_date": "{close_date}",
      "close_rate": "{close_rate}",
      "direction": "{direction}",
      "exit_reason": "{exit_reason}",
      "pair": "{pair}",
      "trade_id": "{trade_id}",
      "type": "exit_fill"
    }
  }
}
