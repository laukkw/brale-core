########################################################
################System toml 配置#########################
########################################################
# 1. INDICATOR
LLM_MODEL_INDICATOR =
LLM_INDICATOR_ENDPOINT =
LLM_INDICATOR_API_KEY =

# 2. STRUCTURE
LLM_MODEL_STRUCTURE =
LLM_STRUCTURE_ENDPOINT =
LLM_STRUCTURE_API_KEY =

# 3. MECHANICS
LLM_MODEL_MECHANICS =
LLM_MECHANICS_ENDPOINT =
LLM_MECHANICS_API_KEY =


#########################################################
##################数据库配置##############################
#########################################################
# PostgreSQL / TimescaleDB 连接字符串
# Docker 环境下默认值已在 docker-compose.yml 中配置，此处留空即可
# 本地开发如需覆盖，格式：postgres://user:password@host:5432/dbname?sslmode=disable
# DATABASE_DSN =
POSTGRES_USER = brale
POSTGRES_PASSWORD = brale
POSTGRES_DB = brale

#########################################################
##################freqtrade 配置##########################
#########################################################
EXEC_USERNAME =
EXEC_SECRET =

# Optional MCP sidecar (Streamable HTTP). When true, make start / bootstrap will include the mcp service.
ENABLE_MCP = false

# Proxy (optional)
# PROXY_ENABLED=true will inject proxy into freqtrade config and container env.
PROXY_ENABLED = false
PROXY_PORT = 7890
PROXY_HOST = host.docker.internal
PROXY_SCHEME = http
PROXY_NO_PROXY = localhost,127.0.0.1,brale,freqtrade

# Go proxy for docker build (recommended in CN network)
GOPROXY = https://goproxy.cn,direct
GOSUMDB = sum.golang.google.cn

#########################################################
##################telegram 推送##########################
#########################################################
NOTIFICATION_ENABLED = false
NOTIFICATION_STARTUP_NOTIFY_ENABLED = false
NOTIFICATION_TELEGRAM_ENABLED = false
NOTIFICATION_TELEGRAM_TOKEN =
NOTIFICATION_TELEGRAM_CHAT_ID = 0

#########################################################
##################feishu 推送############################
#########################################################
NOTIFICATION_FEISHU_ENABLED = false
NOTIFICATION_FEISHU_APP_ID =
NOTIFICATION_FEISHU_APP_SECRET =
NOTIFICATION_FEISHU_BOT_ENABLED = false
NOTIFICATION_FEISHU_BOT_MODE = long_connection
NOTIFICATION_FEISHU_VERIFICATION_TOKEN =
NOTIFICATION_FEISHU_ENCRYPT_KEY =
NOTIFICATION_FEISHU_DEFAULT_RECEIVE_ID_TYPE = chat_id
NOTIFICATION_FEISHU_DEFAULT_RECEIVE_ID =
